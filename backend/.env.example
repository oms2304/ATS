# Server
PORT=4000

# Database (Supabase)
# Runtime: use the "Transaction" pooler URI from Supabase (port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations/db push: use the "Session" direct URI from Supabase (port 5432)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Required only when running the demo seed. These project references are not
# secret, but they must identify two different Supabase projects.
EXPECTED_DEV_SUPABASE_PROJECT_REF=[DEV-PROJECT-REF]
PRODUCTION_SUPABASE_PROJECT_REF=[PRODUCTION-PROJECT-REF]
SEED_TARGET=development
ALLOW_DEMO_SEED=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
# Sender address. To email any recipient, verify a domain in Resend and use an
# address on it, e.g. "ATS for Job Seekers <noreply@yourdomain.com>".
# Leaving this unset falls back to Resend's test sender, which only delivers to
# your own Resend account email.
EMAIL_FROM="ATS for Job Seekers <onboarding@resend.dev>"

# AI (OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=
AI_MODEL=gpt-4o

# Frontend
FRONTEND_URL=http://localhost:3000
